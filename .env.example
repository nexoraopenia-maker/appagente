# ─────────────────────────────────────────────────────────────
# Copia este archivo a `.env.local` y rellena los valores.
# `.env.local` está en .gitignore — nunca lo commitees.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──
# Dashboard de Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secreta: bypasea RLS. Solo se usa en el servidor (webhook). Nunca la expongas al browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic ──
# https://platform.claude.com → API Keys
ANTHROPIC_API_KEY=

# ── Google OAuth (Calendar) ──
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (tipo "Web application")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Debe coincidir EXACTAMENTE con el "Authorized redirect URI" registrado en Google Cloud.
# Local:      http://localhost:3000/api/auth/google/callback
# Producción: https://tu-dominio.com/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Cifrado de tokens en BD (AES-256-GCM) ──
# 32 bytes en base64. Genérala con:
#   openssl rand -base64 32
# Si pierdes o rotas esta clave, los tokens ya guardados quedan indescifrables
# y hay que reconectar WhatsApp y Google Calendar en cada organización.
ENCRYPTION_KEY=

# ── App ──
# Sin barra final. Se usa para construir la URL del webhook y los redirects de OAuth.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── WhatsApp ──
# Las credenciales de WhatsApp NO van aquí: se guardan cifradas por organización
# en la tabla `whatsapp_configs` desde la página /integraciones (multi-tenant).
